{
  "compilerOptions": {
    // Enable latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@tscircuit/core",
    "allowJs": true,

    "baseUrl": ".",

    "paths": {
      "@tscircuit/core/jsx-runtime": ["jsx-runtime.ts"],
      "@tscircuit/core/jsx-dev-runtime": ["jsx-dev-runtime.ts"],
      "lib/*": ["lib/*"]
    },

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["node_modules", "dist", "benchmarking-dist", "references"]
}
